@startuml
title E-Uprava - Dijagram slucajeva korišcenja

left to right direction
scale 1.4
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
skinparam actor {
  BorderColor #0F172A
  BackgroundColor #FFFFFF
}

actor Gost
actor Korisnik

rectangle "Sistem E-Uprava - Vrtici" {
  package "Javni deo" {
    usecase UC1 as "Pregled vrtica"
    usecase UC2 as "Filtriranje vrtica"
    usecase UC3 as "Sortiranje i rangiranje vrtica"
    usecase UC4 as "Poredenje vrtica"
    usecase UC5 as "Pregled statistike"
    usecase UC6 as "Pregled kriticno\npopunjenih vrtica"
    usecase UC7 as "Pregled najboljih opština"
    usecase UC8 as "Preuzimanje PDF\nizveštaja po opštini"
  }

  package "Autentifikacija i korisnik" {
    usecase UC9 as "Registracija"
    usecase UC10 as "Prijava"
    usecase UC11 as "Pregled profila"
    usecase UC12 as "Slanje zahteva\nza upis deteta"
    usecase UC13 as "Pregled sopstvenih\nzahteva za upis"
    usecase UC14 as "Ocenjivanje vrtica"
  }

  package "Admin deo" {
    usecase UC15 as "Dodavanje vrtica"
    usecase UC16 as "Izmena vrtica"
    usecase UC17 as "Brisanje vrtica"
    usecase UC18 as "Pregled svih zahteva\nza upis"
    usecase UC19 as "Odobravanje zahteva"
    usecase UC20 as "Odbijanje zahteva"
    usecase UC21 as "Open data analitika"
    usecase UC22 as "Izracunavanje pokrivenosti"
    usecase UC23 as "Projekcija potreba"
    usecase UC24 as "Preuzimanje javnih\nJSON podataka"
  }
}

actor Admin

Gost --> UC1
Gost --> UC2
Gost --> UC3
Gost --> UC4
Gost --> UC5
Gost --> UC6
Gost --> UC7
Gost --> UC8
Gost --> UC9
Gost --> UC10

Korisnik --> UC1
Korisnik --> UC2
Korisnik --> UC3
Korisnik --> UC4
Korisnik --> UC5
Korisnik --> UC6
Korisnik --> UC7
Korisnik --> UC8
Korisnik --> UC11
Korisnik --> UC12
Korisnik --> UC13
Korisnik --> UC14

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC11
Admin --> UC15
Admin --> UC16
Admin --> UC17
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23
Admin --> UC24

UC5 .> UC6 : <<include>>
UC5 .> UC8 : <<extend>>
UC21 .> UC22 : <<include>>
UC21 .> UC23 : <<include>>
UC21 .> UC24 : <<include>>
UC18 .> UC19 : <<extend>>
UC18 .> UC20 : <<extend>>
UC1 .> UC2 : <<extend>>
UC1 .> UC3 : <<extend>>
UC1 .> UC4 : <<extend>>

note right of Gost
Gost ima pristup samo
javnim podacima i autentifikaciji.
end note

note left of Admin
Admin upravlja samo svojim vrticima
i obraduje zahteve za svoje vrtice.
end note

note bottom of Korisnik
Ulogovani korisnik može da:
- šalje zahtev za upis
- prati svoje zahteve
- ocenjuje vrtice
end note

@enduml
