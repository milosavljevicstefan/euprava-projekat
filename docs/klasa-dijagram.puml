@startuml

' =====================
' ENUMI
' =====================
enum StatusZahteva {
NA_CEKANJU
U_PROVERI
ODOBREN
ODBIJEN
}

' =====================
' KORISNICI
' =====================
class Korisnik {

* id: int
* ime: string
* email: string
* lozinka: string

- login()
- logout()
- pregledProfila()
- pregledStatusaZahteva()
  }

class Admin {

* raspisiKonkurs()
* zatvoriKonkurs()
* azurirajStatusZahteva()
  }

Korisnik <|-- Admin

' =====================
' VRTICI
' =====================
class Vrtic {

* id: int
* naziv: string
* adresa: string
* kapacitet: int
* opstina: string

- dodaj()
- izmeni()
- obrisi()
  }

class Konkurs {

* id: int
* datumPocetka: Date
* datumZavrsetka: Date
* maxMesta: int
* aktivan: bool

- raspisi()
- zatvori()
  }

class ZahtevZaUpis {

* id: int
* datumPodnosenja: Date
* status: StatusZahteva

- posalji()
- proveriStatus()
  }

class Ocena {

* id: int
* vrednost: int
* komentar: string

- oceni()
  }

' =====================
' OTVORENI PODACI
' =====================
class OtvoreniPodaci {

* pregled()
  }

class Statistika {

* id: int
* tip: string
* vrednost: float

- generisi()
  }

class Izvestaj {

* id: int
* opstina: string
* pdfPutanja: string

- generisiPDF()
  }

class ProjekcijaPotreba {

* opstina: string
* procena: int

- izracunaj()
  }

class Pokrovnost {

* opstina: string
* procenat: float

- izracunaj()
  }

class Opstina {

* naziv: string
* brojVrtica: int
* popunjenost: float
  }

class JSONExport {

* eksportuj()
  }

' =====================
' RELACIJE
' =====================

Korisnik "1" -- "*" ZahtevZaUpis
Vrtic "1" -- "*" ZahtevZaUpis
Konkurs "1" -- "*" ZahtevZaUpis

Vrtic "1" -- "*" Konkurs
Vrtic "1" -- "*" Ocena

Admin -- Konkurs
Admin -- ZahtevZaUpis

OtvoreniPodaci -- Statistika
OtvoreniPodaci -- Izvestaj
OtvoreniPodaci -- ProjekcijaPotreba
OtvoreniPodaci -- Pokrovnost
OtvoreniPodaci -- JSONExport

Statistika -- Opstina
Izvestaj -- Opstina
ProjekcijaPotreba -- Opstina
Pokrovnost -- Opstina

@enduml